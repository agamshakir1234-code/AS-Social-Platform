import { useLocation } from 'react-router-dom'
import { Bell, Search } from 'lucide-react'
import { useAuth } from '@/context/AuthContext'
import { getInitials } from '@/utils/helpers'

const TITLES = {
  '/dashboard': 'Dashboard',
  '/clients':   'Clients',
  '/posts':     'Posts',
  '/leads':     'Leads',
  '/kpis':      'KPIs Overview',
  '/settings':  'Settings',
}

export default function Topbar() {
  const { pathname } = useLocation()
  const { user } = useAuth()
  const title = TITLES[pathname] ?? 'AS Social Studio'

  return (
    <header style={{
      height:'56px',
      background:'rgba(242,237,228,0.92)',
      backdropFilter:'blur(20px)',
      borderBottom:'1px solid rgba(58,68,58,0.10)',
      display:'flex',
      alignItems:'center',
      padding:'0 32px',
      gap:'16px',
      flexShrink:0
    }}>
      <h1 style={{
        fontFamily:'Heebo, sans-serif',
        fontSize:'18px',
        fontWeight:600,
        color:'#3A443A',
        flex:1
      }}>{title}</h1>

      <div style={{position:'relative', display:'flex', alignItems:'center'}}>
        <Search size={14} style={{position:'absolute', right:'10px', color:'#8A9B8A'}} />
        <input
          style={{
            padding:'7px 32px 7px 12px',
            border:'1px solid rgba(58,68,58,0.12)',
            borderRadius:'8px',
            fontSize:'12px',
            background:'#FDFCF9',
            color:'#3A443A',
            width:'200px',
            outline:'none'
          }}
          placeholder="חיפוש..."
          readOnly
        />
      </div>

      <button style={{
        width:'32px', height:'32px',
        display:'flex', alignItems:'center', justifyContent:'center',
        borderRadius:'8px', border:'none',
        background:'transparent', cursor:'pointer',
        color:'#8A9B8A', position:'relative'
      }}>
        <Bell size={16} />
        <span style={{
          position:'absolute', top:'6px', right:'6px',
          width:'6px', height:'6px',
          borderRadius:'50%', background:'#BFB3A6'
        }} />
      </button>

      <div style={{
        width:'32px', height:'32px',
        borderRadius:'50%',
        background:'linear-gradient(135deg,#BFB3A6,#A68B7D)',
        display:'flex', alignItems:'center', justifyContent:'center',
        cursor:'pointer'
      }}>
        <span style={{fontSize:'12px', fontWeight:700, color:'white'}}>
          {getInitials(user?.name)}
        </span>
      </div>
    </header>
  )
} 
